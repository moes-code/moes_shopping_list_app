<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="moes_shopping_list_app.Views.EditItemPage">

    <StackLayout Padding="20">
        <Label Text="Edit Shopping Item" FontSize="24" HorizontalOptions="Center" />
        <Entry Placeholder="Item Name" Text="{Binding Item.Name}" />
        <Entry Text="{Binding Item.Quantity}" Keyboard="Numeric" />
        <Button Text="Save" Command="{Binding SaveItemCommand}" />
        <Button Text="Cancel" Command="{Binding CancelCommand}" />
    </StackLayout>
</ContentPage>