<?xml version="1.0" encoding="utf-8"?>
<!--
   Data extraction rules for Moe's Shopping List App (Android 12+).
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Include the shopping list database for cloud backup -->
        <include domain="database" path="shopping_list.db" />
        <include domain="database" path="shopping_list.db-journal" />
        <include domain="database" path="shopping_list.db-shm" />
        <include domain="database" path="shopping_list.db-wal" />
    </cloud-backup>
    <device-transfer>
        <!-- Include the shopping list database for device-to-device transfer -->
        <include domain="database" path="shopping_list.db" />
        <include domain="database" path="shopping_list.db-journal" />
        <include domain="database" path="shopping_list.db-shm" />
        <include domain="database" path="shopping_list.db-wal" />
    </device-transfer>
</data-extraction-rules>
